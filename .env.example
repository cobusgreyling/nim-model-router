# Required: NVIDIA API key from https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=nvapi-your-key-here

# Upstream NIM endpoint (OpenAI-compatible)
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Local proxy bind address
ROUTER_HOST=127.0.0.1
ROUTER_PORT=8080

# Optional: path to custom model registry YAML
# ROUTER_CONFIG=src/nim_model_router/models.yaml

# Optional: persist routing logs to JSONL
# ROUTER_LOG_PATH=data/router.log.jsonl

# Optional: require clients to send this key (Authorization: Bearer ... or X-API-Key)
# ROUTER_API_KEY=local-dev-secret

# Upstream retry behavior
UPSTREAM_MAX_RETRIES=3
UPSTREAM_RETRY_BACKOFF_SECONDS=0.5

# Observability
ENABLE_PROMETHEUS=true
HEALTH_CHECK_UPSTREAM=false

# Request limits
MAX_REQUEST_BODY_BYTES=10485760